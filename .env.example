# ============================================
# Application Configuration (12-Factor App)
# ============================================
APP_NAME="PDF ExtractExt"
VERSION="0.1.0"
DESCRIPTION="API para extracción y procesamiento de PDFs"
DEBUG=true

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# MongoDB Configuration
# ============================================
# Opción 1: Connection string completo (preferido para producción)
# DATABASE_URL=mongodb://admin:changeme@localhost:27017/pdf_extractext?authSource=admin

# Opción 2: Configuración por componentes (desarrollo/local)
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_ROOT_USERNAME=admin
MONGODB_ROOT_PASSWORD=changeme
MONGODB_DATABASE_NAME=pdf_extractext
MONGODB_AUTH_SOURCE=admin

# Legacy config (para compatibilidad)
DATABASE_NAME=pdf_extractext

# ============================================
# Storage Configuration
# ============================================
UPLOAD_PATH=./uploads
